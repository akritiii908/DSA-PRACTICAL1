    "from array import array\n",
    "\n",
    "\n",
    "arr = array('i', [10, 20, 30, 40, 50])\n",
    "\n",
    "\n",
    "i = int(input(\"Enter index: \"))\n",
    "\n",
    "base = arr.buffer_info()[0]\n",
    "\n",
    "print(\"Element:\", arr[i])\n",
    "print(\"Address:\", base + i * arr.itemsize)"
   ]
  }
